{
  "name": "essai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "npm --workspace @essai/web run dev --",
    "dev:mobile": "npm --workspace @essai/mobile run dev --",
    "build": "turbo build",
    "build:web": "npm --workspace @essai/web run build",
    "start:web": "npm --workspace @essai/web run start --",
    "lint": "turbo lint",
    "db:generate": "npm --workspace @essai/web run db:generate",
    "db:push": "npm --workspace @essai/web run db:push",
    "db:studio": "npm --workspace @essai/web run db:studio"
  },
  "devDependencies": {
    "turbo": "^2.10.2"
  }
}
