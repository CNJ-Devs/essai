# Optional for the old Web demo data path. The current mobile-first generation
# API does not require a production Postgres database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/essai?sslmode=require"

# Required for recoverable generation records in production.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Required for encrypted mobile generation requests.
# Values are JSON-stringified RSA-OAEP private JWK objects.
REQUEST_ENCRYPTION_PRIVATE_JWK=""
API_KEY_ENCRYPTION_PRIVATE_JWK=""

# Optional server-side provider keys for local smoke tests or internal tooling.
# The mobile app normally sends the user's provider key encrypted per request.
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
ANTHROPIC_API_KEY=""
