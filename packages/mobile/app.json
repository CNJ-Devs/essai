        "backgroundColor": "#C8AE8B",
        "monochromeImage": "./assets/android/adaptive/monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/web/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9071c74e-32b5-4671-b374-dd49f2ce993f"
